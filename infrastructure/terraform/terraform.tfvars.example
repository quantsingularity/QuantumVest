# Copy to terraform.tfvars and fill in values
# NEVER commit terraform.tfvars to version control

environment      = "dev"
app_name         = "quantumvest"
aws_region       = "us-west-2"
vpc_cidr         = "10.0.0.0/16"
availability_zones   = ["us-west-2a", "us-west-2b", "us-west-2c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]

instance_type     = "t3.medium"
db_instance_class = "db.t3.micro"
db_name           = "quantumvestdb"

# Restricted SSH — use your VPN/bastion CIDR, not 0.0.0.0/0
allowed_ssh_cidr  = "10.0.0.0/8"

# Provide secrets via environment variables to avoid them landing in tfstate:
# export TF_VAR_db_username="appuser"
# export TF_VAR_db_password="$(openssl rand -base64 24)"
