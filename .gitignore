# ===============================================================
# QuantumVest .gitignore
# ===============================================================
# General
*.log
*.tmp
*.swp
*~
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class

# Python Virtual Environment
venv/
ENV/
env/
*/venv/
*/ENV/
*/env/
.venv

# Python Distribution / Installation
.Python
build/
dist/
downloads/
eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Jupyter Notebook
.ipynb_checkpoints

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Flask specific
instance/
.webassets-cache

# Celery stuff
celerybeat-schedule.*

# SageMath files
*.sage.py

# Scrapy files
.scrapy

# Node.js / React / Webpack
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
# It is generally recommended to commit lock files
# package-lock.json
# yarn.lock

# Frontend build artifacts
/web-frontend/build/
/web-frontend/dist/
/mobile-frontend/build/
/mobile-frontend/dist/
.cache/

# Jest cache
/web-frontend/.jest-cache
/mobile-frontend/.jest-cache

# Webpack cache
.webpack/

# Blockchain / Solidity / Truffle / Hardhat
build/contracts/
contracts/build/
artifacts/
cache/
typechain-types/

# Docker
*.dockerignore
# If you store built images or context tarballs locally:
# *.tar
# *.tar.gz

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Kubernetes
# Secrets should ideally be managed outside git, e.g., using Sealed Secrets or Vault.
# If storing unencrypted secrets, uncomment the line below, but this is NOT recommended.
# *-secrets.yaml

# Ansible
*.retry
# Vault password files (should be kept secure and out of git)
*.vault
*.vault_pass
*.vault_password

# IDEs and Editors
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.tmproj

# Large data files (consider Git LFS if needed)
/resources/datasets/*.csv

